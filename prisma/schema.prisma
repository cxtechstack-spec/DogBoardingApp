generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// One record per ConnectXperts client business.
// ghlLocationId is the key that ties this app to their GHL account.
model Client {
  id                           String            @id @default(cuid())
  ghlLocationId                String            @unique
  // Display name shown on the client-facing booking form (request.html) —
  // there's no reliable way to read this from GHL itself (the Get Location
  // API endpoint is Agency-only and 403s for a sub-account PIT), so the
  // business types it in directly.
  businessName                 String?
  // External GHL Form links the client-facing booking form (request.html)
  // sends dog owners to instead of collecting this itself — this business's
  // own GHL Workflow creates/updates the Dog object (and vaccine records,
  // including uploaded proof) from those form submissions. Null means this
  // gate is off and the booking form falls back to its own simple
  // name/breed/notes fields for a new dog, with no vaccine gate at all.
  newDogFormUrl                String?
  vaccineUpdateFormUrl         String?
  // GHL Workflow webhook URL (Inbound Webhook trigger -> Stripe One-Time
  // Charge action, both Customer ID and Amount mapped dynamically from the
  // webhook payload) — this business's own workflow, since it must reference
  // their own Stripe connection. Null means Check Out only emails the balance
  // invoice as before, with no auto-charge attempt.
  balanceAutoChargeWebhookUrl  String?
  // GHL Workflow webhook URL (Inbound Webhook trigger -> Find Contact by the
  // Contact ID in the payload -> Send Email + Send SMS) — lets the business
  // track delivery in GHL itself and use both channels, since a single
  // channel (just SMS or just email) can silently fail to reach someone. If
  // this is blank, Deny falls back to a plain direct SMS instead.
  denialNotificationWebhookUrl String?
  services                     ServiceSettings[]
  addOns                       AddOn[]
  capacityPools                CapacityPool[]
  bookings                     Booking[]
  // Combined cap on add-on selections per day, across the whole add-on list
  // (not per individual add-on) — e.g. Dock Diving + Agility together can hit this cap.
  maxAddOnsPerDay              Int               @default(1)
  // AES-256-GCM ciphertext (see lib/crypto.js) — this business's own GHL Private
  // Integration Token. Null until they complete the GHL Connection step in Settings.
  ghlApiTokenEncrypted         String?
  // Who gets texted when a new booking request comes in — a name for display
  // and the phone number itself. Null means no notification is sent.
  staffNotifyName              String?
  staffNotifyPhone             String?
  // Which of this business's own GHL custom objects/fields represent a dog —
  // every business's Dog object has different field keys, so this maps our
  // concepts (name, breed, notes, vaccine dates) to their actual field keys.
  dogObjectKey                 String?
  dogNameFieldKey              String?
  dogBreedFieldKey             String?
  dogNotesFieldKey             String?
  // Kept distinct from dogNotesFieldKey/each other so behavioral flags (e.g.
  // reactive/aggressive dogs) can't get buried inside routine feeding text —
  // staff need to see safety-relevant info at a glance, not read a paragraph.
  dogFeedingFieldKey           String?
  dogBehavioralFieldKey        String?
  // JSON array of field keys — zero or more vaccine-expiration date fields.
  // "Current" means every listed field has a value and it isn't in the past.
  dogVaccineFieldKeys          String            @default("[]")
  createdAt                    DateTime          @default(now())
  updatedAt                    DateTime          @updatedAt
}

// A named group of physical spaces (e.g. "Kennels", "Crates") that one or more
// services draw from. Services sharing a pool compete for the same spots on a given day.
model CapacityPool {
  id             String            @id @default(cuid())
  clientId       String
  client         Client            @relation(fields: [clientId], references: [id])
  name           String
  totalCapacity  Int
  // Optional overflow pool — when this pool is full, availability and unit
  // assignment also draw from the fallback pool (e.g. Crates <-> Kennels used
  // interchangeably). Set both pools' fallbackPoolId to each other for
  // two-way overflow; one-way is allowed if only one direction should overflow.
  fallbackPoolId String?
  fallbackPool   CapacityPool?     @relation("PoolFallback", fields: [fallbackPoolId], references: [id])
  fallbackFor    CapacityPool[]    @relation("PoolFallback")
  services       ServiceSettings[]
  units          Unit[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

// A specific physical space within a pool (e.g. "Kennel 1"). Unlike the pool's
// totalCapacity (a count), a unit is a hard, single-occupancy resource — Confirm
// blocks assigning a unit that's already taken for overlapping dates.
model Unit {
  id             String       @id @default(cuid())
  capacityPoolId String
  capacityPool   CapacityPool @relation(fields: [capacityPoolId], references: [id])
  name           String
  bookings       Booking[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// Per-client, per-service configuration.
// One row per (client, serviceType) pair — enforced by the unique constraint.
model ServiceSettings {
  id             String       @id @default(cuid())
  clientId       String
  client         Client       @relation(fields: [clientId], references: [id])
  serviceType    ServiceType
  billingUnit    BillingUnit
  baseRate       Float
  // The pool of physical spaces this service draws from. Other services linked to
  // the same pool reduce this service's effective availability on a shared day.
  capacityPoolId String
  capacityPool   CapacityPool @relation(fields: [capacityPoolId], references: [id])
  // JSON array of active day abbreviations: ["MON","TUE","WED","THU","FRI","SAT","SUN"]
  // Days absent from this list are treated as capacity 0 (non-operating).
  activeDays     String
  depositType    DepositType
  depositValue   Float
  depositTiming  String // e.g. "at_booking" or "at_dropoff"
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([clientId, serviceType])
}

// Optional add-ons a client offers (e.g. dock diving, agility, training).
// Clients with no add-ons simply have an empty list.
model AddOn {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  name      String
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// One booking record per stay.
// Dog and owner data are NOT copied here — read live from GHL using the stored IDs.
model Booking {
  id                    String        @id @default(cuid())
  clientId              String
  client                Client        @relation(fields: [clientId], references: [id])
  ghlDogObjectId        String // GHL Custom Object record ID for the dog
  ghlOwnerContactId     String // GHL Contact ID for the owner
  serviceType           ServiceType
  startDate             DateTime // As booked — the final bill uses actualStartDate/actualEndDate instead (see lib/quote.js)
  endDate               DateTime // As booked
  // Real drop-off/pickup dates, set at Check In / Check Out. The final invoice
  // is computed from these, not startDate/endDate, so an extended or
  // early-ended stay is billed for what actually happened, not what was
  // originally booked. Null until each respective action occurs.
  actualStartDate       DateTime?
  actualEndDate         DateTime?
  unitId                String? // Assigned physical unit — null until confirmed
  unit                  Unit?         @relation(fields: [unitId], references: [id])
  // JSON: array of { addOnId, name, price, qty } — snapshot at time of booking
  addOnsSelected        String        @default("[]")
  status                BookingStatus @default(REQUESTED)
  denialReason          String? // Optional staff note when status is DENIED
  lockedRate            Float // Snapshot of base rate at time of booking
  ghlInvoiceId          String? // Deposit invoice, set once created in GHL
  ghlRemainderInvoiceId String? // Balance-due invoice, set at Check Out
  // Captured from the deposit invoice's paid transaction (once it's actually
  // paid) — the Stripe Customer ID needed to auto-charge the final balance at
  // Check Out via this client's balanceAutoChargeWebhookUrl. Null until the
  // deposit is paid and a check-in/check-out has run the capture.
  stripeCustomerId      String?
  // JSON: { checked: bool, timestamp: ISO, details: {} }
  vaccineCheckBooking   String?
  vaccineCheckDropoff   String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

enum ServiceType {
  BOARDING
  DAY_CARE
  DAY_TRAINING
}

enum BillingUnit {
  DAY
  NIGHT
}

enum DepositType {
  NONE
  PERCENT
  FLAT
}

enum BookingStatus {
  REQUESTED
  CONFIRMED
  ACTIVE
  COMPLETED
  DENIED
}
